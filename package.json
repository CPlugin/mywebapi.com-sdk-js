{
  "name": "@mywebapi.com/sdk",
  "version": "0.1.0",
  "license": "MIT",
  "description": "TypeScript client for the CPlugin WebAPI v2 (MT4/MT5 trading-platform management). Auto-generated, fully-typed endpoints over a thin native-fetch wrapper, with OAuth2 token management, retries, pagination helpers, and SignalR real-time streams.",
  "keywords": [
    "cplugin",
    "webapi",
    "mt4",
    "mt5",
    "metatrader",
    "trading",
    "sdk",
    "typescript",
    "api-client",
    "openapi",
    "signalr",
    "oauth2"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CPlugin/mywebapi.com-sdk-js.git"
  },
  "homepage": "https://github.com/CPlugin/mywebapi.com-sdk-js#readme",
  "bugs": {
    "url": "https://github.com/CPlugin/mywebapi.com-sdk-js/issues"
  },
  "scripts": {
    "generate": "orval --config orval.config.ts",
    "build": "rm -rf dist && bun build src/index.ts --outdir dist --target browser --format esm && tsc -p tsconfig.build.json --emitDeclarationOnly --declaration",
    "test": "bun test",
    "test:e2e": "WEBAPI_E2E=1 bun test e2e",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@microsoft/signalr": "^9.0.0 || ^10.0.0"
  },
  "peerDependenciesMeta": {
    "@microsoft/signalr": {
      "optional": true
    }
  },
  "devDependencies": {
    "@microsoft/signalr": "^10.0.0",
    "@types/bun": "latest",
    "orval": "8.19.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
