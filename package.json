{
  "name": "@mywebapi.com/sdk",
  "version": "0.1.1",
  "license": "MIT",
  "description": "Typed TypeScript SDK for the CPlugin WebAPI v2 — manage trading-platform servers from Node.js and browsers. OAuth2, retries, pagination and SignalR real-time included; types regenerated from the OpenAPI spec so they never drift.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CPlugin/mywebapi.com-sdk-js.git"
  },
  "homepage": "https://cplugin.github.io/mywebapi.com-sdk-js/",
  "keywords": [
    "cplugin",
    "webapi",
    "trading",
    "trading-platform",
    "broker",
    "forex",
    "sdk",
    "typescript",
    "api-client",
    "rest-api",
    "openapi",
    "signalr",
    "real-time",
    "oauth2"
  ],
  "bugs": {
    "url": "https://github.com/CPlugin/mywebapi.com-sdk-js/issues"
  },
  "scripts": {
    "generate": "orval --config orval.config.ts",
    "build": "rm -rf dist && bun build src/index.ts --outdir dist --target browser --format esm && tsc -p tsconfig.build.json --emitDeclarationOnly --declaration",
    "test": "bun test",
    "test:e2e": "WEBAPI_E2E=1 bun test e2e",
    "docs": "typedoc",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@microsoft/signalr": "^9.0.0 || ^10.0.0"
  },
  "peerDependenciesMeta": {
    "@microsoft/signalr": {
      "optional": true
    }
  },
  "devDependencies": {
    "@microsoft/signalr": "^10.0.0",
    "@types/bun": "latest",
    "orval": "8.19.0",
    "typedoc": "^0.28.19",
    "typescript": "^5.4.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
