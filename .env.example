# CPlugin WebAPI SDK — example environment.
# Copy to `.env` (gitignored) and fill in your credentials:  cp .env.example .env

# --- Environment (staging is the safe default) ---
WEBAPI_BASE_URL=https://pre.mywebapi.com
WEBAPI_AUTH_SERVER=https://pre.auth.cplugin.net

# --- Production (uncomment to target prod) ---
# WEBAPI_BASE_URL=https://cloud.mywebapi.com
# WEBAPI_AUTH_SERVER=https://auth.cplugin.net

# --- Credentials (required) ---
# Create and manage API keys in the Toolbox (https://toolbox.cplugin.com for prod,
# https://pre.toolbox.cplugin.com for staging). Choose your environment above first.
WEBAPI_CLIENT_ID=your-client-id
WEBAPI_CLIENT_SECRET=your-client-secret

# --- Optional ---
# Trade platform GUID. Created and managed in the Toolbox. Leave empty and run
# `bun examples/01-hello.ts` to list platforms accessible to your credentials.
WEBAPI_TRADE_PLATFORM=
WEBAPI_SYMBOL=EURUSD
